APP_NAME=Telegram Shop Platform API
APP_ENV=local
DEBUG=true
API_V1_PREFIX=/api/v1

DATABASE_URL=postgresql+asyncpg://postgres:postgres@postgres:5432/telegram_shop
REDIS_URL=redis://redis:6379/0

TELEGRAM_BOT_TOKEN=
TELEGRAM_WEBAPP_BOT_TOKEN=
TELEGRAM_SELLER_CHAT_ID=

JWT_SECRET_KEY=change-me-in-local-env
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=60
TELEGRAM_AUTH_MAX_AGE_SECONDS=86400

UPLOADS_DIR=uploads
PUBLIC_UPLOADS_URL=/uploads

CORS_ORIGINS=http://localhost:5173,http://localhost:5174,http://localhost:3000
