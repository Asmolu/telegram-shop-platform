APP_NAME=Telegram Shop Platform API
APP_ENV=production
DEBUG=false
API_V1_PREFIX=/api/v1

POSTGRES_DB=telegram_shop
POSTGRES_USER=telegram_shop
POSTGRES_PASSWORD=replace-with-production-postgres-password
DATABASE_URL=postgresql+asyncpg://telegram_shop:replace-with-production-postgres-password@postgres:5432/telegram_shop
REDIS_URL=redis://redis:6379/0

TELEGRAM_BOT_TOKEN=
TELEGRAM_WEBAPP_BOT_TOKEN=
TELEGRAM_SELLER_CHAT_ID=
TELEGRAM_SELLER_BOT_USERNAME=

JWT_SECRET_KEY=replace-with-long-random-production-secret
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=60
TELEGRAM_AUTH_MAX_AGE_SECONDS=86400
SELLER_REGISTRATION_EXPIRES_MINUTES=30
SELLER_VERIFICATION_CODE_EXPIRES_MINUTES=10

UPLOADS_DIR=uploads
PUBLIC_UPLOADS_URL=/uploads

CORS_ORIGINS=https://mini-app.example.com,https://seller-panel.example.com

LOG_LEVEL=INFO
LOG_FORMAT=json
ERROR_MONITORING_ENABLED=false
SENTRY_DSN=

CACHE_ENABLED=true
CACHE_PUBLIC_PRODUCTS_TTL_SECONDS=60
CACHE_PUBLIC_PRODUCT_DETAIL_TTL_SECONDS=60
CACHE_TAXONOMY_TTL_SECONDS=300
CACHE_BANNERS_TTL_SECONDS=60
CACHE_REVIEWS_TTL_SECONDS=120

RATE_LIMIT_ENABLED=true
RATE_LIMIT_REDIS_ENABLED=true
RATE_LIMIT_IN_MEMORY_FALLBACK_ENABLED=true
RATE_LIMIT_GLOBAL_REQUESTS=600
RATE_LIMIT_GLOBAL_WINDOW_SECONDS=60
RATE_LIMIT_AUTH_REQUESTS=10
RATE_LIMIT_AUTH_WINDOW_SECONDS=60
RATE_LIMIT_UPLOAD_REQUESTS=30
RATE_LIMIT_UPLOAD_WINDOW_SECONDS=60
RATE_LIMIT_CHECKOUT_REQUESTS=10
RATE_LIMIT_CHECKOUT_WINDOW_SECONDS=60
RATE_LIMIT_PROMO_REQUESTS=30
RATE_LIMIT_PROMO_WINDOW_SECONDS=60
RATE_LIMIT_REVIEW_REQUESTS=10
RATE_LIMIT_REVIEW_WINDOW_SECONDS=60
